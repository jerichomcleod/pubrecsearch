# PostgreSQL — Docker container (see docker/README.md to start it)
# Start with: docker compose -f docker/docker-compose.yml up -d
DATABASE_URL=postgresql://pubrecsearch:changeme@localhost:5432/pubrecsearch

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=<r2_access_key_id>
R2_SECRET_KEY=<r2_secret_access_key>
R2_BUCKET=pubrecsearch-raw

# Email alerts via Resend — optional; leave blank to disable alerts entirely
RESEND_API_KEY=
ALERT_EMAIL=

# SAM.gov free API key — register at https://sam.gov/profile/details
SAM_API_KEY=

# SEC EDGAR — required User-Agent (include your email per SEC policy)
EDGAR_USER_AGENT=PubRecSearch your@email.com

# LDA Lobbying API key (Phase 3)
LDA_API_KEY=
